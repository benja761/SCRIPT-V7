                        Font = Enum.Font.GothamBold,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        AutoButtonColor = false,
                        ZIndex = 13,
                    })
                    Corner(button, 6)
                    local st = Stroke(button, Theme.BorderSoft, 1, 0.34)
                    ApplyHover(button, Theme.Element, Theme.ElementHover, st)

                    local popup = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Panel2,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 34),
                        Size = UDim2.new(1, 0, 0, 0),
                        ClipsDescendants = true,
                        ZIndex = 14,
                    })
                    Corner(popup, 6)
                    Stroke(popup, Theme.BorderSoft, 1, 0.3)
                    Padding(popup, 8, 8, 8, 8)

                    local filter = Create("TextBox", {
                        Parent = popup,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 26),
                        Text = "",
                        PlaceholderText = "search",
                        TextColor3 = Theme.Text,
                        PlaceholderColor3 = Theme.SubText,
                        Font = Enum.Font.Gotham,
                        TextSize = 12,
                        ClearTextOnFocus = false,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 15,
                    })
                    Corner(filter, 6)
                    Stroke(filter, Theme.BorderSoft, 1, 0.34)

                    local results = Create("ScrollingFrame", {
                        Parent = popup,
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 34),
                        Size = UDim2.new(1, 0, 1, -34),
                        ScrollBarThickness = 2,
                        AutomaticCanvasSize = Enum.AutomaticSize.Y,
                        CanvasSize = UDim2.new(),
                        ZIndex = 15,
                    })

                    local resultsLayout = Create("UIListLayout", {
                        Parent = results,
                        Padding = UDim.new(0, 4),
                        SortOrder = Enum.SortOrder.LayoutOrder,
                    })

                    local current = defaultValue
                    local open = false
                    local entries = {}

                    local function renderEntries()
                        local query = string.lower(filter.Text or "")
                        for _, info in ipairs(entries) do
                            local show = query == "" or string.find(string.lower(info.Name), query, 1, true)
                            info.Button.Visible = show
                        end
                    end

                    for _, option in ipairs(options or {}) do
                        local opt = Create("TextButton", {
                            Parent = results,
                            BackgroundColor3 = Theme.Element,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 24),
                            Text = tostring(option),
                            TextColor3 = Theme.Text,
                            Font = Enum.Font.Gotham,
                            TextSize = 12,
                            AutoButtonColor = false,
                            ZIndex = 16,
                        })
                        Corner(opt, 6)
                        local os = Stroke(opt, Theme.BorderSoft, 1, 0.34)
                        ApplyHover(opt, Theme.Element, Theme.ElementHover, os)
                        opt.MouseButton1Click:Connect(function()
                            current = option
                            button.Text = "  " .. tostring(option)
                            open = false
                            Tween(popup, 0.14, {Size = UDim2.new(1, 0, 0, 0)})
                            Tween(wrap, 0.14, {Size = UDim2.new(1, 0, 0, 30)})
                            if callback then callback(option) end
                        end)
                        table.insert(entries, {Name = tostring(option), Button = opt})
                    end)

                    filter:GetPropertyChangedSignal("Text"):Connect(renderEntries)

                    button.MouseButton1Click:Connect(function()
                        open = not open
                        Tween(popup, 0.14, {Size = open and UDim2.new(1, 0, 0, 148) or UDim2.new(1, 0, 0, 0)})
                        Tween(wrap, 0.14, {Size = open and UDim2.new(1, 0, 0, 182) or UDim2.new(1, 0, 0, 30)})
                        renderEntries()
                    end)

                    if callback and current ~= nil then
                        task.defer(function() callback(current) end)
                    end
                    Register(wrap, text)
                    return {Get = function() return current end}
                end

                function section:AddKeybind(text, defaultKey, callback)
                    local currentKey = defaultKey or Enum.KeyCode.Z
                    local waiting = false
                    local button = section:AddButton(text .. ": " .. currentKey.Name, function()
                        waiting = true
                        button.Text = text .. ": ..."
                    end)
                    UIS.InputBegan:Connect(function(input, gp)
                        if gp or not waiting then return end
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            waiting = false
                            currentKey = input.KeyCode
                            button.Text = text .. ": " .. currentKey.Name
                            if callback then callback(currentKey) end
                        end
                    end)
                    return {Get = function() return currentKey end}
                end

                function section:AddColorPicker(text, defaultColor, callback, applyToAccent)
                    local start = defaultColor or Theme.Accent
                    local h, s, v = start:ToHSV()

                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 30),
                        ClipsDescendants = true,
                    })

                    local button = Create("TextButton", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Size = UDim2.new(1, 0, 0, 30),
                        Text = "",
                        AutoButtonColor = false,
                    })
                    Corner(button, 6)
                    local buttonStroke = Stroke(button, Theme.BorderSoft, 1, 0.34)
                    ApplyHover(button, Theme.Element, Theme.ElementHover, buttonStroke)

                    local label = Create("TextLabel", {
                        Parent = button,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 10, 0, 0),
                        Size = UDim2.new(1, -46, 1, 0),
                        Text = text,
                        TextColor3 = Theme.Text,
                        Font = Enum.Font.Gotham,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                    })

                    local preview = Create("Frame", {
                        Parent = button,
                        AnchorPoint = Vector2.new(1, 0.5),
                        Position = UDim2.new(1, -8, 0.5, 0),
                        Size = UDim2.new(0, 18, 0, 18),
                        BackgroundColor3 = start,
                        BorderSizePixel = 0,
                    })
                    Corner(preview, 4)
                    Stroke(preview, Theme.BorderSoft, 1, 0.28)

                    local panel = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Panel2,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 34),
                        Size = UDim2.new(1, 0, 0, 0),
                        ClipsDescendants = true,
                    })
                    Corner(panel, 6)
                    Stroke(panel, Theme.BorderSoft, 1, 0.3)
                    Padding(panel, 8, 8, 8, 8)

                    local hue = Create("Frame", {Parent = panel, BackgroundColor3 = Theme.Element, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, 0, 0, 10)})
                    Corner(hue, 999)
                    Stroke(hue, Theme.BorderSoft, 1, 0.34)
                    local hueGradient = Instance.new("UIGradient")
                    hueGradient.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
                        ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                        ColorSequenceKeypoint.new(0.34, Color3.fromRGB(0, 255, 0)),
                        ColorSequenceKeypoint.new(0.51, Color3.fromRGB(0, 255, 255)),
                        ColorSequenceKeypoint.new(0.68, Color3.fromRGB(0, 0, 255)),
                        ColorSequenceKeypoint.new(0.85, Color3.fromRGB(255, 0, 255)),
                        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
                    })
                    hueGradient.Parent = hue

                    local sat = Create("Frame", {Parent = panel, BackgroundColor3 = Theme.Element, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 24), Size = UDim2.new(1, 0, 0, 10)})
                    Corner(sat, 999)
                    Stroke(sat, Theme.BorderSoft, 1, 0.34)

                    local val = Create("Frame", {Parent = panel, BackgroundColor3 = Theme.Element, BorderSizePixel = 0, Position = UDim2.new(0, 0, 0, 48), Size = UDim2.new(1, 0, 0, 10)})
                    Corner(val, 999)
                    Stroke(val, Theme.BorderSoft, 1, 0.34)

                    local open = false
                    local function updateColor()
                        local c = Color3.fromHSV(h, s, v)
                        preview.BackgroundColor3 = c
                        if callback then callback(c) end
                        if applyToAccent then
                            self.ParentWindow:SetAccent(c)
                        end
                    end

                    local function bindSlider(frame, setter)
                        local dragging = false
                        frame.InputBegan:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                dragging = true
                                setter(math.clamp((input.Position.X - frame.AbsolutePosition.X) / frame.AbsoluteSize.X, 0, 1))
                            end
                        end)
                        UIS.InputChanged:Connect(function(input)
                            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                                setter(math.clamp((input.Position.X - frame.AbsolutePosition.X) / frame.AbsoluteSize.X, 0, 1))
                            end
                        end)
                        UIS.InputEnded:Connect(function(input)
                            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                                dragging = false
                            end
                        end)
                    end

                    bindSlider(hue, function(p) h = p updateColor() end)
                    bindSlider(sat, function(p) s = p updateColor() end)
                    bindSlider(val, function(p) v = p updateColor() end)

                    button.MouseButton1Click:Connect(function()
                        open = not open
                        Tween(panel, 0.14, {Size = open and UDim2.new(1, 0, 0, 64) or UDim2.new(1, 0, 0, 0)})
                        Tween(wrap, 0.14, {Size = open and UDim2.new(1, 0, 0, 98) or UDim2.new(1, 0, 0, 30)})
                    end)

                    updateColor()
                    Register(wrap, text)
                    return {Get = function() return preview.BackgroundColor3 end}
                end

                table.insert(self.Sections, section)
                return section
            end

            table.insert(tab.SubTabs, sub)
            return sub
        end

        function tab:Show()
            for _, t in ipairs(self.ParentWindow.Tabs) do
                if t.Button then
                    t:UpdateButtonState(false)
                end
                for _, s in ipairs(t.SubTabs) do
                    s.Page.Visible = false
                    if s.Button then
                        s.Button.Visible = false
                    end
                end
            end

            self.ParentWindow.CurrentTab = self
            self:UpdateButtonState(true)
            self.ParentWindow.SubTabsHolder.Visible = self.ParentWindow._BottomTabsVisible and (#self.SubTabs > 0) and not self.ParentWindow.Minimized
            for _, s in ipairs(self.SubTabs) do
                if s.Button then
                    s.Button.Visible = true
                end
            end
            if self.CurrentSub then
                self.CurrentSub:Show()
            elseif self.SubTabs[1] then
                self.SubTabs[1]:Show()
            end
            self.ParentWindow:EnsurePreviewPanel()
            if self.ParentWindow.PreviewPanel then
                self.ParentWindow.PreviewPanel.Visible = self.Name == "Visuals" and self.ParentWindow.PreviewEnabled and self.ParentWindow.MenuVisible and not self.ParentWindow.Minimized
            end
        end

        tab.Button = button
        button.MouseButton1Click:Connect(function()
            self:PlayMenuSound("pop")
            tab:Show()
        end)

        table.insert(self.Tabs, tab)
        return tab
    end


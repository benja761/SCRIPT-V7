                        TextColor3 = Theme.Text,
                        TextSize = 13,
                        Font = Enum.Font.GothamBold,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 14,
                    })
                    local valueText = Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0.65, 0, 0, 0),
                        Size = UDim2.new(0.35, 0, 0, 16),
                        Text = "",
                        TextColor3 = Theme.Text,
                        TextSize = 13,
                        Font = Enum.Font.GothamBold,
                        TextXAlignment = Enum.TextXAlignment.Right,
                        ZIndex = 14,
                    })
                    local bar = Create("Frame", {
                        Parent = wrap,
                        BackgroundColor3 = Theme.Element,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 0, 0, 24),
                        Size = UDim2.new(1, 0, 0, 8),
                        ZIndex = 14,
                    })
                    Corner(bar, 999)
                    Stroke(bar, Theme.Border, 1, 0.24)
                    local fill = Create("Frame", {
                        Parent = bar,
                        BackgroundColor3 = section.ParentWindow.Accent,
                        BorderSizePixel = 0,
                        Size = UDim2.new(0, 0, 1, 0),
                        ZIndex = 15,
                    })
                    Corner(fill, 999)
                    local knob = Create("Frame", {
                        Parent = bar,
                        BackgroundColor3 = Theme.Text,
                        BorderSizePixel = 0,
                        AnchorPoint = Vector2.new(0.5, 0.5),
                        Position = UDim2.new(0, 0, 0.5, 0),
                        Size = UDim2.new(0, 12, 0, 12),
                        ZIndex = 16,
                    })
                    Corner(knob, 999)

                    local dragging = false
                    local current = default or min
                    local function applyPercent(p)
                        p = math.clamp(p, 0, 1)
                        current = min + ((max - min) * p)
                        if math.abs(current - math.floor(current)) < 0.001 then
                            current = math.floor(current)
                        else
                            current = math.floor(current * 10 + 0.5) / 10
                        end
                        valueText.Text = formatValue(current)
                        fill.Size = UDim2.new(p, 0, 1, 0)
                        knob.Position = UDim2.new(p, 0, 0.5, 0)
                        if callback then callback(current) end
                    end
                    if max == min then applyPercent(0) else applyPercent((current - min) / (max - min)) end
                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = true
                            applyPercent((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
                        end
                    end)
                    UserInputService.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            applyPercent((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
                        end
                    end)
                    UserInputService.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                    end)
                    self:RegisterSearch(wrap, text)
                    return {Get=function() return current end}
                end


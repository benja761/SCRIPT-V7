                    local function formatNumber(num)
                        if integer then
                            return tostring(math.floor(num + 0.5))
                        end
                        return string.format("%.1f", num)
                    end
                    local function setPercent(percent)
                        percent = math.clamp(percent, 0, 1)
                        local raw = min + ((max - min) * percent)
                        value = integer and math.floor(raw + 0.5) or math.floor(raw * 10 + 0.5) / 10
                        fill.Size = UDim2.new(percent, 0, 1, 0)
                        valueLabel.Text = formatNumber(value)
                        if callback then
                            callback(value)
                        end
                    end

                    setPercent((value - min) / (max - min))

                    bar.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = true
                            setPercent((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
                        end
                    end)
                    UIS.InputChanged:Connect(function(input)
                        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                            setPercent((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
                        end
                    end)
                    UIS.InputEnded:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            dragging = false
                        end
                    end)

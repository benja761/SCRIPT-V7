local function applySearch()
    local q = string.lower(searchBox.Text or "")
    local active = currentMain and pages[currentMain]
    if not active or not currentSub then return end
    local page = active.Subs[currentSub]
    if not page then return end
    for _, card in ipairs(page:GetChildren()) do
        if card:IsA("Frame") then
            local found = q == ""
            for _, d in ipairs(card:GetDescendants()) do
                if d:IsA("TextLabel") or d:IsA("TextButton") then
                    if string.find(string.lower(d.Text or ""), q, 1, true) then
                        found = true
                        break
                    end
                end
            end
            card.Visible = found
        end
    end
end
searchBox:GetPropertyChangedSignal("Text"):Connect(applySearch)


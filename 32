    function self:ApplySearch(query)
        query = string.lower(query or "")
        for _, tab in ipairs(self.Tabs) do
            for _, sub in ipairs(tab.SubTabs) do
                local active = tab.Active and sub.Active
                for _, section in ipairs(sub.Sections) do
                    local visibleCount = 0
                    for _, entry in ipairs(section.SearchEntries) do
                        local match = query == "" or string.find(entry.Query, query, 1, true)
                        entry.Root.Visible = active and match
                        if entry.Root.Visible then
                            visibleCount += 1
                        end
                    end
                    section.Root.Visible = active and (query == "" or visibleCount > 0)
                end
            end
        end
    end

    function self:SelectSubTab(sub)
        local parentTab = sub.ParentTab
        for _, each in ipairs(parentTab.SubTabs) do
            each.Active = false
            each.Page.Visible = false
            Tween(each.Button, 0.12, {BackgroundColor3 = Theme.Panel})
            Tween(each.TextLabel, 0.12, {TextColor3 = Theme.Text, TextTransparency = 0.08})
            Tween(each.Indicator, 0.12, {BackgroundTransparency = 1, Size = UDim2.new(0, 0, 0, 2)})
        end
        sub.Active = true
        sub.Page.Visible = true
        sub.Page.Position = UDim2.new(0, 12, 0, 0)
        Tween(sub.Page, 0.15, {Position = UDim2.new(0, 0, 0, 0)})
        Tween(sub.Button, 0.12, {BackgroundColor3 = Theme.Element})
        Tween(sub.TextLabel, 0.12, {TextColor3 = Theme.AccentText, TextTransparency = 0})
        sub.Indicator.BackgroundColor3 = self.Accent
        Tween(sub.Indicator, 0.12, {BackgroundTransparency = 0.18, Size = UDim2.new(0, 18, 0, 2)})
        self:ApplySearch(self.SearchBox.Text)
    end

    function self:SelectTab(tab)
        for _, each in ipairs(self.Tabs) do
            each.Active = false
            each.Page.Visible = false
            Tween(each.Button, 0.12, {BackgroundColor3 = Theme.Panel})
            Tween(each.IconLabel, 0.12, {TextColor3 = Theme.SubText})
            Tween(each.TextLabel, 0.12, {TextColor3 = Theme.SubText, TextTransparency = 0.14})
            Tween(each.Indicator, 0.12, {BackgroundTransparency = 1, Size = UDim2.new(0, 0, 0, 2)})
            for _, sub in ipairs(each.SubTabs) do
                if sub.Button then
                    sub.Button.Visible = false
                end
                sub.Page.Visible = false
            end
        end

        tab.Active = true
        self.CurrentTab = tab
        tab.Page.Visible = true
        tab.Page.Position = UDim2.new(0, 14, 0, 0)
        Tween(tab.Page, 0.15, {Position = UDim2.new(0, 0, 0, 0)})
        Tween(tab.Button, 0.12, {BackgroundColor3 = Theme.Element})
        Tween(tab.IconLabel, 0.12, {TextColor3 = self.Accent})
        Tween(tab.TextLabel, 0.12, {TextColor3 = Theme.AccentText, TextTransparency = 0})
        tab.Indicator.BackgroundColor3 = self.Accent
        Tween(tab.Indicator, 0.12, {BackgroundTransparency = 0.14, Size = UDim2.new(0, 16, 0, 2)})

        self.SubHolder.Visible = (not self.Minimized) and (#tab.SubTabs > 0)
        for _, sub in ipairs(tab.SubTabs) do
            sub.Button.Visible = true
        end
        if #tab.SubTabs > 0 then
            self:SelectSubTab(tab.SubTabs[1])
        else
            self:ApplySearch(self.SearchBox.Text)
        end
    end


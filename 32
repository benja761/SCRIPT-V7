                        Corner(opt, 6)
                        local optSt = Stroke(opt, Theme.Border, 1, 0.24)
                        setHover(opt, Theme.Element, Theme.ElementHover, optSt)
                        opt.MouseButton1Click:Connect(function()
                            current = value
                            label.Text = value
                            open = false
                            Tween(drop, 0.15, {Size = UDim2.new(1, 0, 0, 0)})
                            Tween(wrap, 0.15, {Size = UDim2.new(1, 0, 0, 34)})
                            arrow.Text = "˅"
                            if callback then callback(current) end
                        end)
                        table.insert(refs, {Button = opt, Query = string.lower(value)})
                    end
                    search:GetPropertyChangedSignal("Text"):Connect(refreshFilter)
                    button.MouseButton1Click:Connect(function()
                        open = not open
                        local target = math.min(150, 50 + (#items * 32))
                        Tween(drop, 0.15, {Size = open and UDim2.new(1, 0, 0, target) or UDim2.new(1, 0, 0, 0)})
                        Tween(wrap, 0.15, {Size = open and UDim2.new(1, 0, 0, 38 + target) or UDim2.new(1, 0, 0, 34)})
                        arrow.Text = open and "˄" or "˅"
                        if open then refreshFilter() end
                    end)
                    if callback and current ~= nil then task.defer(function() callback(current) end) end
                    self:RegisterSearch(wrap, text)
                    return {Get=function() return current end}
                end

                function section:AddKeybind(text, defaultKey, callback)
                    local current = defaultKey or Enum.KeyCode.Z
                    local waiting = false
                    local button
                    button = self:AddButton(text .. ": " .. current.Name, function()
                        waiting = true
                        button.Text = text .. ": ..."
                    end)
                    UserInputService.InputBegan:Connect(function(input, gp)
                        if gp or not waiting then return end
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            waiting = false
                            current = input.KeyCode
                            button.Text = text .. ": " .. current.Name
                            if callback then callback(current) end
                        end
                    end)
                    return {Get=function() return current end}
                end

                table.insert(sub.Sections, section)
                return section
            end

            table.insert(tab.SubTabs, sub)
            return sub
        end

        button.MouseButton1Click:Connect(function()
            self:SelectTab(tab)
        end)

        table.insert(self.Tabs, tab)
        return tab
    end

    function self:ToggleMinimize()
        self.Minimized = not self.Minimized
        if self.Minimized then
            Tween(self.Main, 0.16, {Size = UDim2.new(0, 930, 0, 96)})
            self.Pages.Visible = false
            self.SearchFrame.Visible = false
            self.SubHolder.Visible = false
        else
            Tween(self.Main, 0.16, {Size = UDim2.new(0, 930, 0, 580)})
            task.wait(0.03)
            self.Pages.Visible = true
            self.SearchFrame.Visible = true
            self.SubHolder.Visible = self.CurrentTab and #self.CurrentTab.SubTabs > 0 or false
        end
    end

    minBtn.MouseButton1Click:Connect(function()
        self:ToggleMinimize()
    end)

    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        self:ApplySearch(searchBox.Text)
    end)

    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == self.HideKey then
            self.MenuVisible = not self.MenuVisible
            main.Visible = self.MenuVisible
        end
    end)

    return self
end


                    local swStroke = Stroke(sw, Theme.Border, 1, 0.24)
                    local knob = Create("Frame", {
                        Parent = sw,
                        BackgroundColor3 = Theme.Text,
                        BorderSizePixel = 0,
                        Position = UDim2.new(0, 3, 0.5, -7),
                        Size = UDim2.new(0, 14, 0, 14),
                        ZIndex = 15,
                    })
                    Corner(knob, 999)
                    local state = default and true or false
                    local function render()
                        if state then
                            Tween(sw, 0.12, {BackgroundColor3 = Theme.AccentSoft})
                            Tween(swStroke, 0.12, {Color = section.ParentWindow.Accent, Transparency = 0.08})
                            Tween(knob, 0.12, {Position = UDim2.new(1, -17, 0.5, -7)})
                        else
                            Tween(sw, 0.12, {BackgroundColor3 = Theme.Element})
                            Tween(swStroke, 0.12, {Color = Theme.Border, Transparency = 0.24})
                            Tween(knob, 0.12, {Position = UDim2.new(0, 3, 0.5, -7)})
                        end
                    end
                    sw.MouseButton1Click:Connect(function()
                        state = not state
                        render()
                        if callback then callback(state) end
                    end)
                    render()
                    if callback then task.defer(function() callback(state) end) end
                    self:RegisterSearch(wrap, text)
                    return {Get=function() return state end}
                end

                function section:AddSlider(text, min, max, default, callback)
                    local wrap = Create("Frame", {
                        Parent = holder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 42),
                        ZIndex = 14,
                    })
                    Create("TextLabel", {
                        Parent = wrap,
                        BackgroundTransparency = 1,
                        Position = UDim2.new(0, 0, 0, 0),
                        Size = UDim2.new(0.65, 0, 0, 16),

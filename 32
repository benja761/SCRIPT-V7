    function self:RegisterAccentObject(object, mode)
        if not object then
            return
        end
        object:SetAttribute("AccentMode", mode)
        table.insert(self.AccentObjects, object)
        if mode == "bg" then
            object.BackgroundColor3 = Theme.Accent
        elseif mode == "text" then
            object.TextColor3 = Theme.Accent
        elseif mode == "stroke" then
            object.Color = Theme.Accent
        end
    end

    function self:RefreshAccent()
        for _, object in ipairs(self.AccentObjects) do
            if object and object.Parent then
                local mode = object:GetAttribute("AccentMode")
                if mode == "bg" then
                    object.BackgroundColor3 = Theme.Accent
                elseif mode == "text" then
                    object.TextColor3 = Theme.Accent
                elseif mode == "stroke" then
                    object.Color = Theme.Accent
                end
            end
        end
        for _, render in ipairs(self.ToggleRenderers) do
            pcall(render)
        end
        if self.BrandAccent then
            self.BrandAccent.TextColor3 = Theme.Accent
        end
    end

    function self:SetAccent(color)
        Theme.Accent = color
        Theme.AccentSoft = color:Lerp(Color3.new(0, 0, 0), 0.28)
        self:RefreshAccent()
    end

    function self:PlayMenuSound(kind)
        if not self._MenuSounds then
            return
        end
        if kind == "open" then
            SimpleSound("rbxassetid://6026984224", 0.28, 1)
        elseif kind == "close" then
            SimpleSound("rbxassetid://6026984224", 0.26, 0.94)
        else
            SimpleSound("rbxassetid://9118828561", 0.18, 1)
        end
    end

    function self:ReflowNotifications()
        for index, data in ipairs(self.Notifications) do
            if data and data.Card and data.Card.Parent then
                local y = -((index - 1) * 54)
                Tween(data.Card, 0.16, {Position = UDim2.new(1, 0, 1, y)})
                if data.Shadow and data.Shadow.Parent then
                    Tween(data.Shadow, 0.16, {Position = UDim2.new(1, -2, 1, y - 2)})
                end
            end
        end
    end

